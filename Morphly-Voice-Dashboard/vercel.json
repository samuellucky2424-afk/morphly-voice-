{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "buildCommand": "npm run build:static",
  "outputDirectory": "dist-static",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/[...path]?path=:path*"
    }
  ],
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 30
    }
  }
}
