rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() &&
        (request.auth.token.admin == true || request.auth.token.role == 'admin');
    }

    // All writes go through the Vercel API and Firebase Admin SDK. This keeps
    // role, status, credit, payment, notification and audit fields authoritative.
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    match /presence/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow write: if false;
    }

    match /notifications/{notificationId} {
      // Audience filtering is enforced by the authenticated Vercel API.
      allow read, write: if false;
    }

    match /app_config/{documentId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
