# Browser-safe Firebase configuration (embedded in the static dashboard build).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_VAPID_KEY=
VITE_MORPHLY_API_URL=https://your-morphly-api.vercel.app/api

# Server-only Firebase Admin credentials. Configure these in Vercel, never VITE_* variables.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----\n"
# Alternative to the three values above: JSON text or base64-encoded service-account JSON.
# FIREBASE_SERVICE_ACCOUNT_JSON=
# FIRESTORE_DATABASE_ID=(default)

MORPHLY_SIGNUP_CREDITS=0

# CORS. Local Morphly origins on ports 18000 are included automatically.
APP_ALLOWED_ORIGINS=https://your-dashboard.example.com

# Flutterwave secrets are server-only.
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_SECRET_HASH=
FLUTTERWAVE_REDIRECT_URL=https://your-dashboard.example.com/payment/complete
MORPHLY_APP_URL=https://your-dashboard.example.com

# Optional JSON array overriding the built-in USD credit packages.
# MORPHLY_CREDIT_PLANS_JSON=[{"id":"starter","label":"Starter","credits":1000,"amount":10,"currency":"USD"}]
MORPHLY_REPORTING_CURRENCY=USD
